---
import { Icon } from 'astro-icon/components';
import PixelGrid from '../components/PixelGrid';
import Projects from '../sections/Projects.astro';
import Services from '../sections/Services.astro';
import TerminalSection from '../sections/TerminalSection.astro';
import Footer from '../sections/Footer.astro';
import Layout from '../layouts/Layout.astro';
import LogoHorizontal from '../components/LogoHorizontal.astro';
import { GITHUB_URL } from '../constants';
import { TYPEWRITER_WORDS, HERO_MESSAGES } from '../data';
---

<Layout
  title="DOCOBYTE — Compile the Future"
  description="DOCOBYTE is a software house and startup lab. We build, consult, operate, and ship software so your business keeps moving."
>
  <PixelGrid client:only="react" />

  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/60 bg-black/70 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2 group text-zinc-100 hover:text-brand-400 transition-colors">
        <LogoHorizontal class="h-8 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8 font-mono text-sm">
        <a href="#services" class="text-zinc-400 hover:text-white transition-colors">Services</a>
        <a href="#projects" class="text-zinc-400 hover:text-white transition-colors">Products</a>
        <a href="#terminal" class="text-zinc-400 hover:text-white transition-colors">Terminal</a>
        <a href="#contact" class="text-zinc-400 hover:text-white transition-colors">Contact</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-zinc-800 bg-zinc-950/80 text-zinc-400 hover:text-white hover:border-brand-500 transition-colors">
          <Icon name="lucide:github" class="w-4 h-4" aria-hidden="true" />
          <span>GitHub</span>
        </a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-zinc-300 hover:text-white" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800/60 bg-black/90 px-4 py-4 font-mono text-sm space-y-3">
      <a href="#services" class="block text-zinc-400 hover:text-white">Services</a>
      <a href="#projects" class="block text-zinc-400 hover:text-white">Products</a>
      <a href="#terminal" class="block text-zinc-400 hover:text-white">Terminal</a>
      <a href="#contact" class="block text-zinc-400 hover:text-white">Contact</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener" class="flex items-center gap-2 text-zinc-400 hover:text-brand-400">
        <Icon name="lucide:github" class="w-4 h-4" aria-hidden="true" />
        GitHub
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section id="hero" class="hero-section snap-section relative flex flex-col items-center justify-center px-4 text-center bg-void-900/40 border-b border-zinc-700/50 overflow-hidden">
    <!-- Floating orbs -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="orb absolute -top-20 -left-10 w-72 h-72 rounded-full bg-brand-500/8 blur-[80px] animate-[hero-orb-a_18s_ease-in-out_infinite]"></div>
      <div class="orb absolute -bottom-16 right-0 w-80 h-80 rounded-full bg-signal-500/8 blur-[100px] animate-[hero-orb-b_22s_ease-in-out_infinite]"></div>
      <div class="orb absolute top-1/3 right-1/4 w-56 h-56 rounded-full bg-pulse-500/6 blur-[90px] animate-[hero-orb-c_16s_ease-in-out_infinite]"></div>
    </div>
    <!-- Grain overlay -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.035] mix-blend-overlay" aria-hidden="true" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E&quot;); background-repeat: repeat; background-size: 200px 200px;"></div>
    <!-- Vertical accent lines -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 left-0 w-px h-64 bg-brand-500/20"></div>
      <div class="absolute top-0 right-0 w-px h-64 bg-brand-500/20"></div>
      <div class="absolute top-0 left-1/3 w-[1px] h-32 bg-zinc-700/20"></div>
      <div class="absolute top-0 right-1/3 w-[1px] h-32 bg-zinc-700/20"></div>
    </div>
    <div class="max-w-4xl">
      <p class="font-mono text-brand-400 text-sm mb-4 tracking-widest uppercase opacity-80 hero-tagline">Compile the Future</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-normal tracking-tight text-white mb-6">
        We Build <span class="cursor-blink font-light" id="typewriter"></span>
      </h1>
      <p class="hero-msg text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed min-h-[3.5rem] transition-opacity duration-500">
        {HERO_MESSAGES[0]}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#services" class="px-6 py-3 rounded-md bg-brand-500 hover:bg-brand-600 text-black font-semibold font-mono transition-colors">
          Explore Services
        </a>
        <a href="#contact" class="px-6 py-3 rounded-md border border-zinc-700 hover:border-brand-500 bg-black/80 text-white font-mono transition-colors">
          Get in Touch
        </a>
      </div>
    </div>

    <a href="#services" aria-label="Scroll to services" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-zinc-600 hover:text-brand-400 transition-colors animate-bounce cursor-pointer">
      <Icon name="lucide:chevron-down" class="w-6 h-6" aria-hidden="true" />
    </a>
  </section>

  <Services />
  <Projects />
  <TerminalSection />
  <Footer />

  <script define:vars={{ words: TYPEWRITER_WORDS, messages: HERO_MESSAGES }}>
    const typeEl = document.getElementById('typewriter');
    let typeIndex = 0, charIndex = 0, isDeleting = false;

    function typeLoop() {
      const word = words[typeIndex];
      typeEl.textContent = isDeleting ? word.slice(0, charIndex - 1) : word.slice(0, charIndex + 1);
      if (isDeleting) charIndex--; else charIndex++;
      if (!isDeleting && charIndex === word.length) { isDeleting = true; setTimeout(typeLoop, 1600); }
      else if (isDeleting && charIndex === 0) { isDeleting = false; typeIndex = (typeIndex + 1) % words.length; setTimeout(typeLoop, 400); }
      else { setTimeout(typeLoop, isDeleting ? 60 : 120); }
    }
    typeLoop();

    const msgEl = document.querySelector('.hero-msg');
    let msgIndex = 0;
    function rotateMsg() {
      msgIndex = (msgIndex + 1) % messages.length;
      msgEl.style.opacity = '0';
      setTimeout(() => {
        msgEl.textContent = messages[msgIndex];
        msgEl.style.opacity = '1';
      }, 500);
    }
    setInterval(rotateMsg, 5000);

    // Mouse parallax — orbs & rings follow cursor subtle
    const hero = document.querySelector('.hero-section');
    const orbs = hero.querySelectorAll('.orb');
    const rings = hero.querySelector('.orbital-rings');
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      orbs.forEach((orb, i) => {
        const factor = 8 + i * 4;
        orb.style.transform = `translate(${x * factor}px, ${y * factor}px)`;
      });
      if (rings) rings.style.transform = `translate(${x * 3}px, ${y * 3}px)`;
    });
    hero.addEventListener('mouseleave', () => {
      orbs.forEach(orb => orb.style.transform = '');
      if (rings) rings.style.transform = '';
    });

    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
    mobileMenu.querySelectorAll('a').forEach(link =>
      link.addEventListener('click', () => mobileMenu.classList.add('hidden'))
    );
  </script>
</Layout>
