---
import { Icon } from 'astro-icon/components';
import MatrixBackground from '../components/MatrixBackground';
import PixelGrid from '../components/PixelGrid';
import SocialLinks from '../components/SocialLinks.astro';
import Projects from '../sections/Projects.astro';
import TerminalSection from '../sections/TerminalSection.astro';
import Layout from '../layouts/Layout.astro';
import LogoHorizontal from '../components/LogoHorizontal.astro';
import { GITHUB_URL, X_URL } from '../constants';
---

<Layout>
  <MatrixBackground client:only="react" />

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-zinc-800/60 bg-black/70 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2 group text-zinc-100 hover:text-brand-400 transition-colors">
        <LogoHorizontal class="h-8 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8 font-mono text-sm">
        <a href="#projects" class="text-zinc-400 hover:text-white transition-colors">Projects</a>
        <a href="#terminal" class="text-zinc-400 hover:text-white transition-colors">AI Terminal</a>
        <a href="#contact" class="text-zinc-400 hover:text-white transition-colors">Contact</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-zinc-800 text-zinc-400 hover:text-white hover:border-brand-500 transition-colors">
          <Icon name="lucide:github" class="w-4 h-4" aria-hidden="true" />
          <span>GitHub</span>
        </a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-zinc-300 hover:text-white" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800/60 bg-black/90 px-4 py-4 font-mono text-sm space-y-3">
      <a href="#projects" class="block text-zinc-400 hover:text-white">Projects</a>
      <a href="#terminal" class="block text-zinc-400 hover:text-white">AI Terminal</a>
      <a href="#contact" class="block text-zinc-400 hover:text-white">Contact</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener" class="flex items-center gap-2 text-zinc-400 hover:text-brand-400">
        <Icon name="lucide:github" class="w-4 h-4" aria-hidden="true" />
        GitHub
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative flex flex-col items-center justify-center min-h-[90vh] px-4 text-center">
    <div class="max-w-4xl">
      <p class="font-mono text-brand-400 text-sm mb-4 tracking-widest uppercase opacity-80">Startup Lab</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight text-white mb-6">
        We Build <span class="cursor-blink" id="typewriter"></span>
      </h1>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Minimal, fast, and scalable software. From AI agents to API services — engineered byte by byte.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#projects" class="px-6 py-3 rounded-md bg-brand-500 hover:bg-brand-600 text-black font-semibold font-mono transition-colors">
          Explore Projects
        </a>
        <a href="#terminal" class="px-6 py-3 rounded-md border border-zinc-700 hover:border-brand-500 text-white font-mono transition-colors">
          Open Terminal
        </a>
      </div>
    </div>
  </section>

  <Projects />
  <TerminalSection />

  <!-- Footer -->
  <footer id="contact" class="border-t border-zinc-900 bg-black mt-24">
    <div class="max-w-6xl mx-auto px-4 py-16">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12 font-mono">
        <!-- Kolom 1 -->
        <div class="space-y-4">
          <div class="flex items-center gap-2 text-zinc-100">
            <LogoHorizontal class="h-6 w-auto" />
          </div>
          <p class="text-xs text-zinc-400 leading-relaxed font-sans">
            Minimal, fast, and scalable software. From AI agents to API services.
          </p>
          <div class="flex items-center gap-2 text-xs text-brand-400">
            <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
            <span>System Online</span>
          </div>
        </div>

        <!-- Kolom 2 -->
        <div class="space-y-4">
          <h4 class="text-sm font-semibold text-white uppercase tracking-wider font-sans">Sitemap</h4>
          <ul class="space-y-2 text-xs text-zinc-400">
            <li><a href="#projects" class="hover:text-brand-400 transition-colors">Projects</a></li>
            <li><a href="#terminal" class="hover:text-brand-400 transition-colors">AI Terminal</a></li>
            <li><a href="#contact" class="hover:text-brand-400 transition-colors">Contact</a></li>
          </ul>
        </div>

        <!-- Kolom 3 -->
        <div class="space-y-4">
          <h4 class="text-sm font-semibold text-white uppercase tracking-wider font-sans">Connect</h4>
          <ul class="space-y-2 text-xs text-zinc-400">
            <li><a href={GITHUB_URL} target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">GitHub</a></li>
            <li><a href={X_URL} target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">X (Twitter)</a></li>
            <li><a href="https://www.instagram.com/docobyte" target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">Instagram</a></li>
            <li><a href="https://www.tiktok.com/@docobyte" target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">TikTok</a></li>
            <li><a href="https://www.facebook.com/profile.php?id=61591799471879" target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">Facebook</a></li>
          </ul>
        </div>

        <!-- Kolom 4: Pixel Grid Sandbox -->
        <div class="space-y-4">
          <h4 class="text-sm font-semibold text-white uppercase tracking-wider font-sans">Sandbox</h4>
          <div class="h-32 w-full">
            <PixelGrid client:only="react" />
          </div>
        </div>
      </div>

      <!-- Copyright -->
      <div class="border-t border-zinc-900 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 font-mono text-xs text-zinc-500">
        <div>DOCOBYTE &copy; <span id="year"></span>. All rights reserved.</div>
        <div class="flex gap-4">
          <a href="#" class="hover:text-white transition-colors">Privacy</a>
          <a href="#" class="hover:text-white transition-colors">Terms</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Typewriter
    const typeWords = ['Software', 'AI Agents', 'API Services', 'Websites'];
    let typeIndex = 0, charIndex = 0, isDeleting = false;
    const typeEl = document.getElementById('typewriter');
    function typeLoop() {
      const word = typeWords[typeIndex];
      typeEl.textContent = isDeleting ? word.slice(0, charIndex - 1) : word.slice(0, charIndex + 1);
      if (isDeleting) charIndex--; else charIndex++;
      if (!isDeleting && charIndex === word.length) { isDeleting = true; setTimeout(typeLoop, 1600); }
      else if (isDeleting && charIndex === 0) { isDeleting = false; typeIndex = (typeIndex + 1) % typeWords.length; setTimeout(typeLoop, 400); }
      else { setTimeout(typeLoop, isDeleting ? 60 : 120); }
    }
    typeLoop();

    // Mobile menu
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
    mobileMenu.querySelectorAll('a').forEach(link => link.addEventListener('click', () => mobileMenu.classList.add('hidden')));

    // Year
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</Layout>
