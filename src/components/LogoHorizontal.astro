---
import LogoIcon from './LogoIcon.astro';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<div class={`flex items-center gap-3 ${className || ''}`}>
  <LogoIcon class="h-9 w-auto text-zinc-900 dark:text-white shrink-0" />
  <div class="flex flex-col justify-center leading-none">
    <div class="font-logo text-xl tracking-wide select-none">
      <span class="font-extrabold text-zinc-900 dark:text-white">DOCO</span><span class="font-light text-zinc-500 dark:text-zinc-400">BYTE</span>
    </div>
  </div>
</div>

