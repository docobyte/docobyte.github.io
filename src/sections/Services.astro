---
import { Icon } from 'astro-icon/components';
import { SERVICES, WHY } from '../data';
---

<section id="services" class="snap-section flex items-center px-4">
  <div class="w-full max-w-6xl mx-auto py-24">
    <div class="flex items-center gap-3 mb-2">
      <span class="font-mono text-brand-500">$</span>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight">What We Do</h2>
      <span class="flex-1 h-px bg-zinc-800 ml-4"></span>
    </div>
    <p class="text-zinc-500 text-sm font-mono mb-10 tracking-wide">
      Develop · Optimize · Create · Outcome — <span class="text-zinc-400">every byte connected</span>
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      {SERVICES.map(service => (
        <article class="group p-6 rounded-xl border border-zinc-800 bg-zinc-950/50 glow-border relative overflow-hidden">
          <div class="absolute -top-3 -right-3 p-3 text-[100px] font-mono font-black text-zinc-800/20 select-none leading-none tracking-widest">{service.letter}</div>
          <div class="flex items-start justify-between mb-4 relative z-10">
            <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-400 font-mono font-bold">
              {service.letter}
            </div>
            <Icon name="lucide:arrow-up-right" class="w-5 h-5 text-zinc-600 group-hover:text-brand-400 transition-colors" />
          </div>
          <h3 class="text-lg font-semibold mb-2 text-zinc-100 relative z-10">{service.title}</h3>
          <p class="text-zinc-400 text-sm leading-relaxed relative z-10">{service.desc}</p>
        </article>
      ))}
    </div>

    <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-8 md:p-10">
      <h3 class="text-lg font-semibold text-white mb-6">Why DOCOBYTE?</h3>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {WHY.map(item => (
          <li class="flex items-center gap-3 text-sm text-zinc-400">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-500" />
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
