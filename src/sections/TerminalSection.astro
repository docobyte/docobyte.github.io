---
import Terminal from '../components/Terminal';
---

<section id="terminal" class="snap-section flex items-center px-4">
  <div class="w-full max-w-5xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
      <span class="font-mono text-brand-500">$</span>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight">AI Terminal</h2>
      <span class="flex-1 h-px bg-zinc-800 ml-4"></span>
    </div>
    <Terminal client:load />
  </div>
</section>
